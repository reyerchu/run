generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id                String   @id @default(cuid())
  name              String
  nameEn            String?
  region            String
  country           String?
  city              String
  date              DateTime
  registrationStart DateTime?
  registrationEnd   DateTime?
  distances         String
  status            String   @default("upcoming")
  websiteUrl        String?
  registrationUrl   String?
  description       String?
  imageUrl          String?
  source            String?
  sourceUrl         String?
  verified          Boolean  @default(false)
  featured          Boolean  @default(false)
  isRecurring       Boolean  @default(false)
  estimatedMonth    Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  photos    Photo[]
  reviews   Review[]
  favorites Favorite[]
  raceLogs  RaceLog[]
  posts     Post[]

  @@index([region, date])
  @@index([status])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  photos    Photo[]
  reviews   Review[]
  favorites Favorite[]
  raceLogs  RaceLog[]
  posts     Post[]
}

model Photo {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Review {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  content   String
  rating    Int      @default(5)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Favorite {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model CrawlLog {
  id          String   @id @default(cuid())
  source      String
  status      String
  message     String?
  eventsFound Int      @default(0)
  eventsAdded Int      @default(0)
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RaceLog {
  id          String   @id @default(cuid())
  userId      String
  eventId     String?
  eventName   String
  date        DateTime
  distance    String
  distanceKm  Float?
  finishTime  String?
  finishSecs  Int?
  pace        String?
  rank        Int?
  totalRunner Int?
  category    String?
  note        String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id])

  @@index([userId, date])
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  imageUrl  String?
  eventId   String?
  type      String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
